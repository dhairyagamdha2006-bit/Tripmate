# -----------------------------------------------------------------------------
# Tripmate environment variables
#
# Copy to `.env.local` for local development, or configure them in Vercel for
# production. Required variables are marked [required]. Optional integrations
# degrade gracefully when unset — see README.md for what becomes unavailable.
# -----------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# [required] Postgres connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/tripmate"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# [required] 32+ random bytes, base64url. Generate with: openssl rand -base64 32
AUTH_SECRET=""
# [required in production] Canonical site URL, e.g. https://tripmate.example.com.
# Locally, NextAuth defaults to http://localhost:3000.
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional — hides the "Sign in with Google" button when unset).
# Configure at https://console.cloud.google.com/ with redirect URI:
#   ${AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Stripe -----------------------------------------------------------------
# Stripe is used for payment authorization (manual capture) and SetupIntents.
# Without these values the payment flow is disabled and bookings cannot run.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret from `stripe listen` or the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=""

# --- Travel providers -------------------------------------------------------
# Amadeus Self-Service is the primary flight/hotel search provider.
# https://developers.amadeus.com/
AMADEUS_CLIENT_ID=""
AMADEUS_CLIENT_SECRET=""
# Either `test.api.amadeus.com` (default) or `api.amadeus.com` for production.
AMADEUS_HOSTNAME="test.api.amadeus.com"

# Optional additional flight/hotel providers. Leave unset to use the mock
# providers which return deterministic sample data flagged as PENDING_FULFILLMENT.
DUFFEL_ACCESS_TOKEN=""
HOTELBEDS_API_KEY=""
HOTELBEDS_SECRET=""

# --- AI (Vercel AI SDK) -----------------------------------------------------
# Anthropic is preferred when both keys are set. Set AI_PROVIDER to force one.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# One of `anthropic`, `openai`, or empty to auto-select from keys above.
# When neither key is set, Tripmate falls back to deterministic rule-based replies.
AI_PROVIDER=""

# --- Email (Resend) ---------------------------------------------------------
# Transactional email. Without RESEND_API_KEY emails are logged to stdout only.
RESEND_API_KEY=""
EMAIL_FROM="Tripmate <hello@tripmate.example.com>"

# --- Cron -------------------------------------------------------------------
# [required] Shared secret the Vercel cron job sends as a Bearer token.
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# --- App URL ----------------------------------------------------------------
# Used in email links and shareable itinerary URLs. Must match AUTH_URL in prod.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Server-only fallback (used by cron / webhooks that do not expose NEXT_PUBLIC_*).
APP_URL="http://localhost:3000"
